# WalletConnect project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# Deployed contract addresses on Ethereum Sepolia
NEXT_PUBLIC_SUSD_ADDRESS=0x
NEXT_PUBLIC_VAULT_ADDRESS=0x
NEXT_PUBLIC_PEG_DEFENDER_ADDRESS=0x
NEXT_PUBLIC_CROSS_CHAIN_BUYBACK_ADDRESS=0x

# Deployed contract addresses on Arbitrum Sepolia
NEXT_PUBLIC_SUSD_ARB_ADDRESS=0x
NEXT_PUBLIC_CROSS_CHAIN_BUYBACK_ARB_ADDRESS=0x

# Server-side RPC and Data Streams credentials (never expose to browser)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
DATA_STREAMS_ENDPOINT=https://api.testnet-dataengine.chain.link
DATA_STREAMS_CLIENT_ID=YOUR_CLIENT_ID
DATA_STREAMS_CLIENT_SECRET=YOUR_CLIENT_SECRET
